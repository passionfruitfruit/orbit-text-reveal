{
  "name": "personal-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.17 <23"
  },
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "serve": "python3 -m http.server 4173 --bind 127.0.0.1",
    "sync:legacy": "node scripts/sync-legacy-assets.mjs",
    "dev": "npm run sync:legacy && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "npm run sync:legacy && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "react-server-dom-webpack": "19.2.6",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  }
}
